{
  "name": "@byronwade/seed-faker",
  "version": "0.1.0",
  "description": "Faker-backed data provider for @byronwade/seed — richer fake data and locales",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src"
  },
  "dependencies": {
    "@byronwade/core": "workspace:*",
    "@byronwade/seed": "workspace:*"
  },
  "peerDependencies": {
    "@faker-js/faker": ">=9.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "author": "Byron Wade",
  "homepage": "https://github.com/byronwade/fakebase#readme",
  "bugs": {
    "url": "https://github.com/byronwade/fakebase/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byronwade/fakebase.git",
    "directory": "packages/seed-faker"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "faker",
    "seed",
    "fake-data",
    "fakebase",
    "provider"
  ]
}
