{
  "name": "@fakebase/cli",
  "version": "0.1.0",
  "description": "CLI for Fakebase — init, dev, studio, migrate, types, seed, and more",
  "license": "MIT",
  "type": "module",
  "bin": {
    "fakebase": "./dist/bin.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-templates.mjs",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fakebase/core": "workspace:*",
    "@fakebase/auth": "workspace:*",
    "@fakebase/adapter-memory": "workspace:*",
    "@fakebase/adapter-json": "workspace:*",
    "@fakebase/adapter-sqlite": "workspace:*",
    "@fakebase/adapter-pglite": "workspace:*",
    "@fakebase/client": "workspace:*",
    "@fakebase/migrations": "workspace:*",
    "@fakebase/seed": "workspace:*",
    "@fakebase/seed-faker": "workspace:*",
    "@fakebase/types": "workspace:*",
    "@fakebase/test-utils": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "chokidar": "^3.6.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "author": "Byron Wade",
  "homepage": "https://github.com/byronwade/fakebase#readme",
  "bugs": {
    "url": "https://github.com/byronwade/fakebase/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/byronwade/fakebase.git",
    "directory": "packages/cli"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "supabase",
    "local",
    "dev",
    "nextjs",
    "prototype",
    "fakebase"
  ]
}
