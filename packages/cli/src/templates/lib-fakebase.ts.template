import { createClient } from "fakebase";
import { createMemoryKernel } from "@fakebase/adapter-memory";
import appSchema from "../fakebase/schema";
import type { Database } from "../database.types";

const kernel = createMemoryKernel<Database>(appSchema);

export const fakebase = createClient<Database>("local", "dev-key", { kernel });

